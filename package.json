{
  "name": "lcs-scs-visualizer",
  "private": true,
  "version": "1.1.3",
  "type": "module",
  "scripts": {
    "dev": "npm run build:wasm && vite --host 0.0.0.0",
    "build:wasm": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/build-wasm.ps1",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "package:local": "node scripts/package-local.mjs",
    "package:vercel": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-vercel.ps1",
    "release": "npm run build:wasm && npm run build && npm run package:local && npm run package:vercel"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.4",
    "pdf-parse": "^1.1.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^8.0.16"
  }
}
