LCS_AI_API_KEY=your-doubao-key
LCS_AI_MODEL=your-ark-endpoint-or-model-name
LCS_AI_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LCS_AI_DAILY_LIMIT=30

# DeepSeek for non-reference AI questions.
LCS_DEEPSEEK_API_KEY=your-deepseek-key
LCS_DEEPSEEK_MODEL=deepseek-v4-flash
LCS_DEEPSEEK_BASE_URL=https://api.deepseek.com

# Server-side shared quota storage. Use the variables created by Vercel KV,
# or the equivalent Upstash Redis REST variables. Without these, the API falls
# back to server memory and cannot strictly share counts across Vercel instances.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional aliases accepted by api/chat.js.
DOUBAO_API_KEY=
DOUBAO_MODEL=
DOUBAO_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
DEEPSEEK_BASE_URL=
